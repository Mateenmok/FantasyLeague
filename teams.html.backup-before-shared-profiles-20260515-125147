<style id="league-info-npc-profile-pictures">
  body.teams-theme-page .league-profile-top {
    grid-template-columns: 170px 1fr !important;
  }

  body.teams-theme-page .league-profile-avatar-ring {
    width: 154px;
    height: 154px;
    border-radius: 50%;
    padding: 7px;
    background: linear-gradient(
      145deg,
      #f4f6fb 0%,
      #d8dbeb 48%,
      #bcc3d8 100%
    );

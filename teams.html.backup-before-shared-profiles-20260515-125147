    display: flex;
    align-items: center;
    justify-content: center;
    color: #102844;
    font-size: 38px;
    font-weight: 800;
    box-sizing: border-box;
  }

  body.teams-theme-page .league-profile-team-logo-small {
    width: 52px;
    height: 52px;

document.addEventListener("DOMContentLoaded", initProfile);

const NPC_EXTENSIONS = ["png", "jpg", "jpeg", "webp"];
const NPC_BASE_PATH = "images/profile-npcs";

let pokemonDatabase = [];
let pokemonByName = new Map();
let profileStorageKeys = null;

async function initProfile() {
  const avatarImg = document.getElementById("profileAvatar");
  const avatarFallback = document.getElementById("avatarFallback");
  const usernameEl = document.getElementById("profileUsername");
  const emailEl = document.getElementById("profileEmail");
  const statusEl = document.getElementById("profileStatus");
  const uploadInput = document.getElementById("avatarUpload");

  const client = getSupabaseClient();

  if (!client) {
    usernameEl.textContent = "Could not load account";
    statusEl.textContent = "Supabase client was not found.";
    return;
  }

  const { data: sessionData, error: sessionError } = await client.auth.getSession();

  if (sessionError) {
    console.error(sessionError);
    usernameEl.textContent = "Could not load account";
    statusEl.textContent = "There was a problem loading your session.";
    return;
  }

  if (!sessionData || !sessionData.session) {
    window.location.href = "sign-in.html";
    return;
  }

  const user = sessionData.session.user;
  const email = user.email || "";
  const username =
    user.user_metadata?.username ||
    user.user_metadata?.display_name ||
    user.user_metadata?.name ||
    user.user_metadata?.full_name ||
    email.split("@")[0] ||
    "Trainer";

  const profileKey = `fantasy_profile_${user.id || email}`;
  profileStorageKeys = {
    avatar: `${profileKey}_avatar`,
    npc: `${profileKey}_npc`,
    wins: `${profileKey}_wins`,
    losses: `${profileKey}_losses`,
    favorites: `${profileKey}_favorite_pokemon`
  };

  usernameEl.textContent = username;
  if (emailEl) emailEl.textContent = "";
  setFallbackInitial(avatarFallback, username);

  await loadAvatar({
    avatarImg,
    avatarFallback,
    statusEl,
    avatarKey: profileStorageKeys.avatar,
    npcKey: profileStorageKeys.npc
  });

  updateStats(profileStorageKeys.wins, profileStorageKeys.losses);

  uploadInput.addEventListener("change", async (event) => {
    const file = event.target.files && event.target.files[0];

    if (!file) return;

    if (!file.type.startsWith("image/")) {
      statusEl.textContent = "Please choose an image file.";
      return;
    }

    try {
      statusEl.textContent = "Saving profile picture...";
      const dataUrl = await resizeImageFile(file, 512);
      localStorage.setItem(profileStorageKeys.avatar, dataUrl);
      showAvatar(avatarImg, avatarFallback, dataUrl);
      statusEl.textContent = "Profile picture updated.";
    } catch (error) {
      console.error(error);
      statusEl.textContent = "Could not save that image.";
    }
  });

  await initFavoritePokemon();
}

function getSupabaseClient() {
  try {
    if (typeof supabaseClient !== "undefined") {
      return supabaseClient;
    }
  } catch (error) {
    console.error(error);
  }

  if (window.supabaseClient) {
    return window.supabaseClient;
  }

  return null;
}

async function loadAvatar({ avatarImg, avatarFallback, statusEl, avatarKey, npcKey }) {
  const savedAvatar = localStorage.getItem(avatarKey);

  if (savedAvatar) {
    showAvatar(avatarImg, avatarFallback, savedAvatar);
    statusEl.textContent = "";
    return;
  }

  const savedNpc = localStorage.getItem(npcKey);

  if (savedNpc && await imageExists(savedNpc)) {
    showAvatar(avatarImg, avatarFallback, savedNpc);
    statusEl.textContent = "";
    return;
  }

  const npc = await chooseRandomNpc();

  if (npc) {
    localStorage.setItem(npcKey, npc);
    showAvatar(avatarImg, avatarFallback, npc);
  }

  statusEl.textContent = "";
}

function setFallbackInitial(fallbackEl, username) {
  fallbackEl.textContent = (username || "T").trim().charAt(0).toUpperCase();
}

function showAvatar(imgEl, fallbackEl, src) {
  imgEl.onload = () => {
    imgEl.style.display = "block";
    fallbackEl.style.display = "none";
  };

  imgEl.onerror = () => {
    imgEl.style.display = "none";
    fallbackEl.style.display = "flex";
  };

  imgEl.src = src;
}

function npcCandidates() {
  const candidates = [];

  for (let i = 1; i <= 9; i += 1) {
    for (const ext of NPC_EXTENSIONS) {
      candidates.push(`${NPC_BASE_PATH}/npc${i}.${ext}`);
    }
  }

  return candidates;
}

async function chooseRandomNpc() {
  const available = [];

  for (const src of npcCandidates()) {
    if (await imageExists(src)) {
      available.push(src);
    }
  }

  if (!available.length) return "";

  const index = Math.floor(Math.random() * available.length);
  return available[index];
}

function imageExists(src) {
  return new Promise((resolve) => {
    const img = new Image();

    img.onload = () => resolve(true);
    img.onerror = () => resolve(false);

    img.src = `${src}?v=${Date.now()}`;
  });
}

function resizeImageFile(file, maxSize) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();

    reader.onload = () => {
      const img = new Image();

      img.onload = () => {
        const canvas = document.createElement("canvas");
        const scale = Math.min(maxSize / img.width, maxSize / img.height, 1);
        const width = Math.round(img.width * scale);
        const height = Math.round(img.height * scale);

        canvas.width = width;
        canvas.height = height;

        const ctx = canvas.getContext("2d");
        ctx.drawImage(img, 0, 0, width, height);

        resolve(canvas.toDataURL("image/png"));
      };

      img.onerror = reject;
      img.src = reader.result;
    };

    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

function updateStats(winsKey, lossesKey) {
  const wins = Number(localStorage.getItem(winsKey) || 0);
  const losses = Number(localStorage.getItem(lossesKey) || 0);
  const total = wins + losses;

  document.getElementById("lifetimeWL").textContent = `${wins}-${losses}`;
  document.getElementById("winPct").textContent = total ? `${Math.round((wins / total) * 100)}%` : "--";
}

async function initFavoritePokemon() {
  const statusEl = document.getElementById("favoritePokemonStatus");
  const dataList = document.getElementById("pokemonOptions");
  const inputs = Array.from(document.querySelectorAll(".favorite-input"));

  try {
    pokemonDatabase = await loadPokemonDatabase();
    pokemonByName = new Map(pokemonDatabase.map(pokemon => [normalizeNameKey(pokemon.name), pokemon]));

    dataList.innerHTML = pokemonDatabase
      .map(pokemon => `<option value="${escapeHtml(pokemon.name)}"></option>`)
      .join("");

    const savedFavorites = getSavedFavorites();

    inputs.forEach((input, index) => {
      const savedName = savedFavorites[index] || "";
      input.value = savedName;

      renderFavoriteSlot(index, savedName);

      input.addEventListener("change", () => {
        saveFavorite(index, input.value.trim());
      });

      input.addEventListener("blur", () => {
        saveFavorite(index, input.value.trim());
      });
    });

    statusEl.textContent = `${pokemonDatabase.length} Pokémon loaded.`;
  } catch (error) {
    console.error(error);
    statusEl.textContent = "Could not load Pokémon database.";
  }
}

async function loadPokemonDatabase() {
  // Profile page exception:
  // Use the full Pokémon database, not the filtered champions/API list.
  const pokemonJson = await fetchJsonSafe("data/pokemon.json?v=profile-full-pokedex1");
  const fullPokemon = flattenPokemonData(pokemonJson);

  const fullList = [];

  for (const raw of fullPokemon) {
    const normalized = normalizePokemon(raw);

    if (normalized.name) {
      fullList.push(normalized);
    }
  }

  const deduped = [];
  const seen = new Set();

  for (const pokemon of fullList) {
    const key = normalizeNameKey(pokemon.name);

    if (!seen.has(key)) {
      seen.add(key);
      deduped.push(pokemon);
    }
  }

  deduped.sort((a, b) => a.name.localeCompare(b.name));
  return deduped;
}


async function fetchJsonSafe(url) {
  try {
    const response = await fetch(url);

    if (!response.ok) return null;

    return await response.json();
  } catch (error) {
    console.warn(`Could not load ${url}`, error);
    return null;
  }
}

function flattenPokemonData(data) {
  if (!data) return [];

  if (Array.isArray(data)) return data;

  if (Array.isArray(data.pokemon)) return data.pokemon;
  if (Array.isArray(data.results)) return data.results;
  if (Array.isArray(data.data)) return data.data;
  if (Array.isArray(data.species)) return data.species;

  if (typeof data === "object") {
    return Object.values(data).filter(value => value && typeof value === "object");
  }

  return [];
}

function normalizePokemon(raw) {
  const name =
    raw.name ||
    raw.Name ||
    raw.pokemon ||
    raw.Pokemon ||
    raw.species ||
    raw.Species ||
    raw.species_name ||
    raw.label ||
    "";

  return {
    raw,
    name: cleanPokemonName(String(name || "")),
    image: findPokemonImage(raw)
  };
}

function cleanPokemonName(name) {
  return name
    .replace(/_/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function findPokemonImage(raw) {
  const preferredKeys = [
    "sprite", "sprites", "image", "img", "icon", "artwork",
    "image_url", "imageUrl", "front_default", "frontDefault",
    "sprite_url", "spriteUrl"
  ];

  for (const key of preferredKeys) {
    const value = raw[key];

    if (typeof value === "string" && looksLikeImage(value)) {
      return normalizeImagePath(value);
    }

    if (value && typeof value === "object") {
      const nested = findPokemonImage(value);
      if (nested) return nested;
    }
  }

  const recursive = findImageStringRecursive(raw);
  return recursive ? normalizeImagePath(recursive) : "";
}

function findImageStringRecursive(value) {
  if (!value || typeof value !== "object") return "";

  for (const item of Object.values(value)) {
    if (typeof item === "string" && looksLikeImage(item)) {
      return item;
    }

    if (item && typeof item === "object") {
      const nested = findImageStringRecursive(item);
      if (nested) return nested;
    }
  }

  return "";
}

function looksLikeImage(value) {
  return /\.(png|jpg|jpeg|webp|gif|svg)(\?.*)?$/i.test(value) ||
    value.includes("raw.githubusercontent.com") ||
    value.includes("img.pokemondb.net") ||
    value.includes("play.pokemonshowdown.com/sprites") ||
    value.includes("assets.pokemon.com");
}

function normalizeImagePath(path) {
  if (!path) return "";

  if (/^https?:\/\//i.test(path)) return path;
  if (path.startsWith("./")) return path.slice(2);
  if (path.startsWith("/")) return path.slice(1);

  return path;
}

function getSavedFavorites() {
  if (!profileStorageKeys) return ["", "", ""];

  try {
    const parsed = JSON.parse(localStorage.getItem(profileStorageKeys.favorites) || "[]");
    return Array.isArray(parsed) ? [parsed[0] || "", parsed[1] || "", parsed[2] || ""] : ["", "", ""];
  } catch (error) {
    return ["", "", ""];
  }
}

function saveFavorite(index, requestedName) {
  const statusEl = document.getElementById("favoritePokemonStatus");
  const favorites = getSavedFavorites();

  if (!requestedName) {
    favorites[index] = "";
    localStorage.setItem(profileStorageKeys.favorites, JSON.stringify(favorites));
    renderFavoriteSlot(index, "");
    statusEl.textContent = "Favorite cleared.";
    return;
  }

  const pokemon = findPokemonByName(requestedName);

  if (!pokemon) {
    statusEl.textContent = `Could not find "${requestedName}" in the database.`;
    renderFavoriteSlot(index, "");
    return;
  }

  favorites[index] = pokemon.name;
  localStorage.setItem(profileStorageKeys.favorites, JSON.stringify(favorites));

  const input = document.querySelector(`.favorite-slot[data-favorite-slot="${index}"] .favorite-input`);
  if (input) input.value = pokemon.name;

  renderFavoriteSlot(index, pokemon.name);
  statusEl.textContent = `${pokemon.name} saved as favorite ${index + 1}.`;
}

function findPokemonByName(name) {
  const key = normalizeNameKey(name);

  if (pokemonByName.has(key)) return pokemonByName.get(key);

  return pokemonDatabase.find(pokemon => normalizeNameKey(pokemon.name).includes(key)) || null;
}

function renderFavoriteSlot(index, name) {
  const slot = document.querySelector(`.favorite-slot[data-favorite-slot="${index}"]`);
  if (!slot) return;

  const img = slot.querySelector(".favorite-img");
  const empty = slot.querySelector(".favorite-empty");
  const nameEl = slot.querySelector(".favorite-name");
  const pokemon = name ? findPokemonByName(name) : null;

  if (!pokemon) {
    img.removeAttribute("src");
    img.style.display = "none";
    empty.style.display = "inline";
    nameEl.textContent = `Favorite ${index + 1}`;
    return;
  }

  nameEl.textContent = pokemon.name;

  if (pokemon.image) {
    img.onload = () => {
      img.style.display = "block";
      empty.style.display = "none";
    };

    img.onerror = () => {
      img.style.display = "none";
      empty.style.display = "inline";
    };

    img.src = pokemon.image;
  } else {
    img.removeAttribute("src");
    img.style.display = "none";
    empty.style.display = "inline";
    empty.textContent = pokemon.name.charAt(0).toUpperCase();
  }
}

function normalizeNameKey(name) {
  return String(name || "")
    .toLowerCase()
    .replace(/[^a-z0-9]/g, "");
}

function escapeHtml(value) {
  return String(value || "")
    .replaceAll("&", "&amp;")
    .replaceAll('"', "&quot;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;");
}
